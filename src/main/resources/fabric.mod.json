{
	"schemaVersion": 1,
	"id": "builders_toolkit",
	"version": "${version}",
	"name": "Builder's Toolkit",
	"description": "A Minecraft QoL / building mod that allows anyone to create normally creative-exclusive in Survival without commands.",
	"authors": [
		"netheriteREX"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/builders_toolkit/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.netheriterex.builders_toolkit.BuilderSToolkit"
		],
		"client": [
			"net.netheriterex.builders_toolkit.BuilderSToolkitClient"
		],
		"fabric-datagen": [
			"net.netheriterex.builders_toolkit.datagen.BuilderSToolkitDataGenerator"
		]
	},
	"mixins": [
		"builders_toolkit.mixins.json",
		{
			"config": "builders-toolkit.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}